# Database (default: SQLite at backend/db.sqlite3 — leave DATABASE_URL unset)
#
# PostgreSQL (psycopg2-binary is in requirements.txt):
# DATABASE_URL=postgres://USER:PASSWORD@127.0.0.1:5432/sms_db
#
# MySQL (pip install -r requirements-mysql.txt first):
# DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/sms_db

# Production
# DJANGO_SECRET_KEY=
# DJANGO_DEBUG=false
# DJANGO_ALLOWED_HOSTS=example.com,www.example.com

# Email (attendance reports to parents). Dev default: console backend (see settings.py).
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DJANGO_DEFAULT_FROM_EMAIL=noreply@example.com
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true

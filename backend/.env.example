# Database (default: SQLite at backend/db.sqlite3 — leave DATABASE_URL unset)
#
# PostgreSQL (psycopg2-binary is in requirements.txt):
# DATABASE_URL=postgres://USER:PASSWORD@127.0.0.1:5432/sms_db
#
# MySQL (pip install -r requirements-mysql.txt first):
# DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/sms_db

# Production
# DJANGO_SECRET_KEY=
# DJANGO_DEBUG=false
# DJANGO_ALLOWED_HOSTS=example.com,www.example.com

# Email — OTP to your real inbox
# Copy this file to `backend/.env` (same folder as this example). Django loads it automatically.
#
# Console-only (no SMTP): leave everything below commented out.
#
# Gmail — real OTP emails:
# 1) Google Account → Security → turn on 2-Step Verification → App passwords → create one for “Mail”.
# 2) In `backend/.env`, uncomment and set (use your address and the 16-char app password, no spaces):
#
# DJANGO_DEFAULT_FROM_EMAIL=you@gmail.com
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=you@gmail.com
# EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
#
# Google Sign-In — same Client ID as frontend VITE_GOOGLE_CLIENT_ID
# In Google Cloud Console → Credentials → OAuth 2.0 Client ID (Web):
#   Authorized JavaScript origins: http://localhost:3000
# GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
#
# OTP tuning (optional):
# OTP_EXPIRY_MINUTES=5
# OTP_RESEND_COOLDOWN_SECONDS=30
# OTP_MAX_BURST_SENDS=3
# OTP_BURST_WINDOW_SECONDS=900
# OTP_MAX_SENDS_PER_HOUR=5

# Local dev: `npm run dev` (or `npm start`) starts Django + Vite. Set SMS_DEV_AUTO_FREE=0 to skip automatic port cleanup.
#
# Django API — leave unset in dev to use Vite proxy (/api → :8000).
# Set only if you call Django directly (CORS must allow the frontend origin):
# VITE_API_URL=http://127.0.0.1:8000

# PostgreSQL, SMTP (OTP email), etc. — see backend/.env.example
#
# --- Google Sign-In (Google Cloud Console) ---
# 1. Create a project → enable OAuth consent screen → Credentials → OAuth client ID (Web).
# 2. Authorized JavaScript origins: http://localhost:3000
# 3. Copy the Client ID below (same value as GOOGLE_OAUTH_CLIENT_ID in backend/.env).
# VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Local dev: run `npm run dev:stack` (Vite + Django) or two terminals: `npm run dev` + `npm run dev:django`.
#
# Django API ‚Äî leave unset in dev to use Vite proxy (/api ‚Üí :8000).
# Set only if you call Django directly (CORS must allow the frontend origin):
# VITE_API_URL=http://127.0.0.1:8000

# PostgreSQL etc. are configured on the Django side ‚Äî see backend/.env.example

# Firebase (optional ‚Äî Google login)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
